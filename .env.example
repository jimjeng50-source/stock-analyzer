# FinMind API Token（免費申請：https://finmindtrade.com/）
FINMIND_TOKEN=your_finmind_token_here

# Anthropic Claude API Key（https://console.anthropic.com/）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Telegram 推播目標 Chat ID（向你的 Bot 傳送 /start 後，向 @userinfobot 查詢即可取得）
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === v3 新增設定 ===

# Email 推播設定（使用 Gmail App Password 或其他 SMTP）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL=target_email@gmail.com

# 產業鏈分析追蹤清單（逗號分隔，留空=使用系統預設）
WATCHLIST_SEMICONDUCTOR=2330,2303,2454,3711,5483
WATCHLIST_AI_SERVER=2317,2382,3037,6274
WATCHLIST_EV=6409,1513,2231

# ===== v4 Screener 設定 =====
SCREENER_UNIVERSE_SIZE=200      # 候選池大小（建議初期 200）
SCREENER_TOP_N=5                # 每日推薦數量

# 自訂觀察名單（逗號分隔，這些股票不受流動性篩選限制）
WATCHLIST_CUSTOM=2330,6213,2454
